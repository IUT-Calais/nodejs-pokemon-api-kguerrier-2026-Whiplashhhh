{
  "name": "nodejs-pokedex-api",
  "version": "1.0.0",
  "description": "Nous allons tâcher de créer une API permettant d'effectuer des opérations CRUD sur les pokémons. Ce projet sera réalisé avec Express pour la gestion des routes et avec une base de donnée NoSQL.",
  "main": "build/index.js",
  "scripts": {
    "dev": "nodemon --exec tsx ./src/index.ts",
    "start": "node ./build/index.js",
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "db:reset": "prisma migrate reset --force",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vfourny/nodejs-pokedex-api.git"
  },
  "keywords": [],
  "author": "VANBAELINGHEM--DEZITTER Willem <willem.vanbaelinghem@proton.me>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/vfourny/nodejs-pokedex-api/issues"
  },
  "homepage": "https://github.com/vfourny/nodejs-pokedex-api#readme",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcrypt": "^5.1.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/yamljs": "^0.2.34",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "nodemon": "^3.1.9",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "vitest-mock-extended": "^3.1.0"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
